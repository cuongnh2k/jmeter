        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Insert Table Data" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="insert data MST_REGION" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.sql.Sql

// Get working directory path
def workDir = vars.get(&apos;WORK_DIRECTORY_PATH&apos;)

// Instance SQL
def dbUrl = vars.get(&apos;DB_URL&apos;)
def dbUsername = vars.get(&apos;DB_USERNAME&apos;)
def dbPassword = vars.get(&apos;DB_PASSWORD&apos;)
def sql = Sql.newInstance(dbUrl, dbUsername, dbPassword, &quot;com.mysql.jdbc.Driver&quot;)

log.debug(&quot;Connected to database: ${dbUrl}&quot;)

// Declare dataset
def dataset = []
def headers = []

// Read dataset from CSV file
def dataFile = new File(&quot;${workDir}/_dataset/MST_REGION.csv&quot;)
dataFile.readLines().eachWithIndex { line, index -&gt;
   if (index == 0) {
	headers = line.split(&apos;,&apos;)
   } else {
	def entries = line.split(&apos;,&apos;)
	dataset.add(entries)
   }
}

// Make insert query
def params = [&apos;?&apos;] * headers.size()
def insertQueryString = &quot;INSERT INTO MST_REGION (${headers.join(&apos;, &apos;)}) VALUES (${params.join(&apos;, &apos;)})&quot;
log.debug(insertQueryString)

// Execute insert data query
dataset.each { row -&gt;
   log.debug(row.toString())
   sql.execute(insertQueryString, row)
}</stringProp>
          </JSR223Sampler>
